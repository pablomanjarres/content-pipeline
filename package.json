{
  "name": "content-pipeline",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron-entry.cjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx watch server/index.ts\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "dev:electron": "concurrently \"vite\" \"tsx watch server/index.ts\" \"sleep 3 && electron .\"",
    "build": "tsc -b && vite build",
    "build:app": "node scripts/build-app.js && electron-builder --mac --dir",
    "install:app": "npm run build:app && cp -R \"dist-app/mac-arm64/Content Pipeline.app\" /Applications/ && echo 'Installed to /Applications'",
    "update:app": "npm run install:app",
    "start": "NODE_ENV=production tsx server/index.ts",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.contentpipeline.app",
    "productName": "Content Pipeline",
    "directories": {
      "output": "dist-app"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/app-icon.icns",
      "target": ["dir"],
      "darkModeSupport": true
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "data/**/*",
      "assets/**/*",
      "electron-entry.cjs"
    ],
    "extraResources": [
      { "from": "data", "to": "data" }
    ],
    "asar": false
  },
  "dependencies": {
    "@fontsource/instrument-serif": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "framer-motion": "^12.38.0",
    "multer": "^2.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
